# ---------------------------------------------------------------------------
# MSN Partner Hub credentials (BoxingNews — partnerId AA1lKiff)
# Used by the MSN insights puller (agents/etl/msn_insights_etl.py).
# Playwright performs a one-time interactive login (handles MFA if prompted)
# and persists a browser profile under ~/.pgam/msn-session/ for subsequent runs.
# Rotate these by simply replacing the values here — no other config needs to change.
# ---------------------------------------------------------------------------
MSN_EMAIL=
MSN_PASSWORD=

# Optional: path Playwright uses to persist the logged-in browser profile.
# Defaults to ~/.pgam/msn-session if unset. Delete that directory to force re-login.
# MSN_SESSION_DIR=

# Optional: set to "0" to force a visible Chromium window (needed for the
# very first run, or to debug auth/MFA issues). Defaults to headless
# whenever a session profile already exists.
# MSN_HEADLESS=0

# Set to "1" to wire the MSN puller, resolver, and health alert into
# scheduler.py. Default off because Playwright/Chromium can't fit on
# Render's free Python tier; on a Playwright-capable host (local dev,
# Docker, GH Actions) flip this to "1".
# PGAM_MSN_PULLER_ENABLED=1

# Neon DSN that the MSN ETL writes to. Same DB the partner-revenue ETL
# uses — set once and both are happy. Falls back to DATABASE_URL.
# PGAM_DIRECT_DATABASE_URL=postgres://...

# ---------------------------------------------------------------------------
# Supply Compliance & Quality Intelligence agent (Phase 1)
# Daily audit of partner ads.txt against PGAM's sellers.json. Writes findings
# to pgam_direct.compliance_findings + posts a Slack digest.
# ---------------------------------------------------------------------------
# Set to "1" to register the daily 08:30 ET scheduler job.
# PGAM_COMPLIANCE_ENABLED=1
#
# Override the sellers.json URL (the account-scoped path can rotate).
# PGAM_SELLERS_JSON_URL=https://sellers.pgamssp.com/<account>/sellers.json
#
# Limit publishers scanned per run (useful for dev/staging — leave unset in prod).
# PGAM_COMPLIANCE_LIMIT=10
#
# Also fetch + validate /app-ads.txt for each domain (404s tolerated).
# PGAM_COMPLIANCE_APP_ADS_TXT=1
#
# Global crawl rate cap, requests per second (default 2.0).
# PGAM_COMPLIANCE_RATE_HZ=2.0
#
# Phase 2 — conditional RESELLER-line validation. Defaults ON.
# Set to "0" to skip if ll_daily_partner_revenue is stale or you're
# tuning the LL publisher↔domain bridge match thresholds.
# PGAM_COMPLIANCE_RESELLERS=1
#
# Phase 3 — downstream SSP sellers.json audit. Confirms PGAM's seat
# exists in each Rubicon/PubMatic/etc sellers.json. Defaults ON.
# PGAM_COMPLIANCE_DOWNSTREAM=1
#
# Phase 3 — per-publisher compliance score (0..100) snapshotted daily
# into pgam_direct.compliance_publisher_scores_daily. Defaults ON.
# PGAM_COMPLIANCE_SCORING=1
#
# Phase 4 — static schain audit on LL demands + publishers. Defense-in-
# depth audit of supplyChainEnabled / dontAddSupplyChainNode flags;
# complements (does NOT duplicate) the auto-fixer in
# agents/optimization/config_health_scanner.py. Requires LL_UI_EMAIL +
# LL_UI_PASSWORD; degrades to a logged skip if absent. Defaults ON.
# PGAM_COMPLIANCE_SCHAIN=1
#
# Phase 5 — per-app + per-domain compliance audit (LL "Suppliers" view
# granularity). Pulls top N entities by trailing 7d revenue from
# pgam_direct.ll_daily_publisher_{domain,bundle}_demand, audits each
# with the tiered seller_id check + per-entity conditional reseller
# lines. Defaults ON.
# PGAM_COMPLIANCE_PHASE5=1
#
# Top N entities to audit per Phase 5 run (default 200).
# PGAM_COMPLIANCE_PHASE5_TOP_N=200
#
# Dedicated Slack webhook for the daily compliance digest. If set, the
# digest posts here (recommended: a new #compliance channel) instead of
# the shared SLACK_WEBHOOK. Create at https://api.slack.com/apps →
# your app → Incoming Webhooks → Add New Webhook to Workspace, target
# #compliance.
# COMPLIANCE_SLACK_WEBHOOK=https://hooks.slack.com/services/...
